{
  "name": "microsmcp",
  "version": "0.1.0",
  "description": "Standalone MCP server and tester UI for discovering micrOS devices and running micrOS commands.",
  "type": "module",
  "bin": {
    "microsmcp": "dist/mcp/index.js"
  },
  "scripts": {
    "build": "tsc",
    "docker:build": "node scripts/docker-build.mjs",
    "dev": "tsx mcp/index.ts",
    "help": "node scripts/start.mjs --help",
    "start": "node scripts/start.mjs",
    "start:mcp": "node scripts/start.mjs mcp",
    "start:test": "npm run build && node scripts/test.mjs",
    "start:ui": "npm run build && node scripts/start.mjs ui",
    "ui": "npm run build && node scripts/start.mjs ui"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
